{
  "name": "Python 3",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",

  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "dashboard.py"
      ]
    },

    "vscode": {
      "settings": {},
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },

  "updateContentCommand": "[ -f packages.txt ] && sudo apt update && sudo xargs apt install -y < packages.txt; [ -f requirements.txt ] && pip3 install --user -r requirements.txt; pip3 install --user streamlit; echo '✅ Environment ready'",

  "postAttachCommand": {
    "server": "streamlit run dashboard.py --server.enableCORS false --server.enableXsrfProtection false"
  },

  "portsAttributes": {
    "8501": {
      "label": "Application",
      "onAutoForward": "openBrowser"
    }
  },

  "forwardPorts": [
    8501
  ]
}